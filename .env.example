# Spotify app credentials (https://developer.spotify.com/dashboard)
# PKCE flow: only the client ID is needed - there is no client secret.
SPOTIFY_CLIENT_ID=
# Must match the redirect URI registered on the Spotify app exactly.
# Spotify rejects http://localhost for apps created after April 2025 - use the loopback IP.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
